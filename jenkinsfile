pipeline {
    agent any

    environment {
        VERSION = '1.0.2'
    }
    stages {
        stage('compile') {
            steps {
                sh 'javac Index.java'
            }
        }
        stage('run') {
            steps {
                sh 'java Index'
                echo "Version: ${VERSION}"
            }
        }
    }

    post {
        always {
            echo 'This will always run'
        }
        success {
            echo 'This will run only if successful'
        }
        failure {
            echo 'This will run only if failed'
        }
    }
}